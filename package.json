{
  "name": "scoregrove",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web-client dev",
    "storybook": "pnpm --filter web-client storybook",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.5.2",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "typescript-eslint>typescript": "6.0.3",
      "@typescript-eslint/eslint-plugin>typescript": "6.0.3",
      "@typescript-eslint/parser>typescript": "6.0.3",
      "@typescript-eslint/utils>typescript": "6.0.3",
      "@typescript-eslint/type-utils>typescript": "6.0.3",
      "@typescript-eslint/typescript-estree>typescript": "6.0.3",
      "@typescript-eslint/project-service>typescript": "6.0.3",
      "@typescript-eslint/tsconfig-utils>typescript": "6.0.3"
    }
  }
}
